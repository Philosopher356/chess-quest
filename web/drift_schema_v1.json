  "fixed_sql": [
    {
      "name": "profiles",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"profiles\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"avatar_id\" INTEGER NOT NULL DEFAULT 0, \"age\" INTEGER NOT NULL DEFAULT 5, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"total_xp\" INTEGER NOT NULL DEFAULT 0, \"current_rank\" INTEGER NOT NULL DEFAULT 0, \"coin_balance\" INTEGER NOT NULL DEFAULT 0, \"puzzle_rating\" INTEGER NOT NULL DEFAULT 600, \"streak_count\" INTEGER NOT NULL DEFAULT 0, \"streak_last_date\" INTEGER NULL, \"is_active\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_active\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "chapter_progress",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"chapter_progress\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"profile_id\" INTEGER NOT NULL, \"chapter_id\" TEXT NOT NULL, \"status\" INTEGER NOT NULL DEFAULT 0, \"stars_earned\" INTEGER NOT NULL DEFAULT 0, \"best_score\" INTEGER NOT NULL DEFAULT 0, \"unlocked_at\" INTEGER NULL, \"completed_at\" INTEGER NULL, UNIQUE (\"profile_id\", \"chapter_id\"));"
        }
      ]
    },
    {
      "name": "exercise_results",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"exercise_results\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"profile_id\" INTEGER NOT NULL, \"exercise_id\" TEXT NOT NULL, \"attempts\" INTEGER NOT NULL DEFAULT 0, \"best_time_ms\" INTEGER NULL, \"stars\" INTEGER NOT NULL DEFAULT 0, \"completed_at\" INTEGER NULL, UNIQUE (\"profile_id\", \"exercise_id\"));"
        }
      ]
    },
    {
      "name": "puzzle_attempts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"puzzle_attempts\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"profile_id\" INTEGER NOT NULL, \"puzzle_id\" TEXT NOT NULL, \"puzzle_fen\" TEXT NOT NULL, \"puzzle_moves\" TEXT NOT NULL, \"solved\" INTEGER NOT NULL DEFAULT 0 CHECK (\"solved\" IN (0, 1)), \"time_ms\" INTEGER NULL, \"rating_change\" INTEGER NOT NULL DEFAULT 0, \"attempted_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
        }
      ]
    },
    {
      "name": "game_history",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"game_history\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"profile_id\" INTEGER NOT NULL, \"pgn\" TEXT NOT NULL, \"result\" INTEGER NOT NULL, \"ai_difficulty\" INTEGER NOT NULL, \"played_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
        }
      ]
    },
    {
      "name": "achievements",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"achievements\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"profile_id\" INTEGER NOT NULL, \"achievement_key\" TEXT NOT NULL, \"unlocked_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), UNIQUE (\"profile_id\", \"achievement_key\"));"
        }
      ]
    },
    {
      "name": "inventory",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"inventory\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"profile_id\" INTEGER NOT NULL, \"item_type\" TEXT NOT NULL, \"item_key\" TEXT NOT NULL, \"is_equipped\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_equipped\" IN (0, 1)), UNIQUE (\"profile_id\", \"item_type\", \"item_key\"));"
        }
      ]
    }
  ]
}